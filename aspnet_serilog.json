{
  "$schema": "https://lnav.org/schemas/format-v1.schema.json",
  "aspnet_serilog": {
    "title": "ASP.NET Serilog",
    "description": "Format for ASP.NET applications using Serilog",
    "file-type": "json",
    "timestamp-field": "@t",
    "timestamp-format": ["%Y-%m-%dT%H:%M:%S.%f%z"],
    "level-field": "@l",
    "opid-field": "@tr",
    "opid": {
      "subid": "@sp"
    },
    "body-field": "@mt",
    "convert-to-local-time": true,
    "line-format": [
      { "field": "__timestamp__" },
      " [",
      { "field": "@l" },
      "] ",
      { "field": "@mt" }
    ],
    "value": {
      "@sp": {
        "kind": "string",
        "identifier": true,
        "description": "Span ID"
      },
      "@tr": {
        "kind": "string",
        "identifier": true,
        "description": "Trace ID"
      },
      "@x": {
        "kind": "string",
        "description": "Exception/error message"
      },
      "ActionId": {
        "kind": "string",
        "identifier": true,
        "description": "Controller action ID"
      },
      "ActionName": {
        "kind": "string",
        "identifier": true,
        "description": "Controller action name"
      },
      "ClientIp": {
        "kind": "string",
        "collate": "ipaddress",
        "identifier": true,
        "description": "Remote IP address of the client"
      },
      "ConnectionId": {
        "kind": "string",
        "identifier": true,
        "description": "Connection ID"
      },
      "ContentType": {
        "kind": "string",
        "identifier": true,
        "description": "MIME content type"
      },
      "Host": {
        "kind": "string",
        "identifier": true,
        "description": "HTTP request host"
      },
      "Method": {
        "kind": "string",
        "identifier": true,
        "description": "HTTP request method"
      },
      "Path": {
        "kind": "string",
        "identifier": true,
        "description": "HTTP request path"
      },
      "PathBase": {
        "kind": "string",
        "identifier": true,
        "description": "HTTP request base path"
      },
      "Protocol": {
        "kind": "string",
        "identifier": true,
        "description": "Network protocol name and version"
      },
      "RequestId": {
        "kind": "string",
        "identifier": true,
        "description": "Request ID"
      },
      "RequestMethod": {
        "kind": "string",
        "identifier": true,
        "description": "HTTP request method"
      },
      "RequestPath": {
        "kind": "string",
        "identifier": true,
        "description": "HTTP request path"
      },
      "Scheme": {
        "kind": "string",
        "identifier": true,
        "description": "Network request scheme"
      },
      "SourceContext": {
        "kind": "string",
        "identifier": true,
        "description": "Class that generated this log entry"
      },
      "StatusCode": {
        "kind": "integer",
        "foreign-key": true,
        "rewriter": ";SELECT :StatusCode || ' (' || coalesce((SELECT message FROM http_status_codes WHERE status = :StatusCode), 'Unknown') || ') '"
      },
      "UserName": {
        "kind": "string",
        "identifier": true,
        "description": "Primary identity of the authenticated user"
      },
      "commandText": {
        "kind": "string",
        "description": "SQL executed by EF"
      }
    }
  }
}
